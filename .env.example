# ═══════════════════════════════════════════════════════════════
# NombaCrypt Shell — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# ── Nomba API Credentials (Sandbox) ──
NOMBA_TEST_CLIENT_ID=your_sandbox_client_id_here
NOMBA_TEST_PRIVATE_KEY=your_sandbox_private_key_here
NOMBA_TEST_ACCOUNT_ID=your_sandbox_account_id_here
NOMBA_API_BASE_URL=https://sandbox.nomba.com/v1

# ── Multi-API Additional Channels (Optional) ──
NOMBA_CHANNEL_B_CLIENT_ID=
NOMBA_CHANNEL_B_PRIVATE_KEY=
NOMBA_CHANNEL_C_CLIENT_ID=
NOMBA_CHANNEL_C_PRIVATE_KEY=

# ── C++ Engine Configuration ──
ENGINE_HTTP_PORT=8080
ENGINE_WS_PORT=8081
ENGINE_BUFFER_CAPACITY=8192
ENGINE_INGEST_THREADS=2
ENGINE_CRYPTO_THREADS=2
ENGINE_DISPATCH_THREADS=3
ENGINE_TELEMETRY_INTERVAL_MS=100

# ── Python Control API ──
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-random-secret
JWT_SECRET_KEY=change-this-to-another-random-secret
DATABASE_URL=sqlite:///nombacrypt.db
CONTROL_API_PORT=5000

# ── Frontend Dashboard ──
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=ws://localhost:5000
NEXT_PUBLIC_ENGINE_WS_URL=ws://localhost:8081

# ── Webhook Configuration ──
WEBHOOK_SECRET=your_webhook_signing_secret
NGROK_AUTH_TOKEN=your_ngrok_auth_token_for_local_testing

# ── Downstream Forwarding (Optional) ──
DOWNSTREAM_WEBHOOK_URL_1=
DOWNSTREAM_WEBHOOK_URL_2=
